# Copy to .env.local and edit. All NEXT_PUBLIC_* vars are exposed to the browser.

# Default network on first load (mainnet | testnet). Persisted per-user via localStorage.
NEXT_PUBLIC_DEFAULT_NETWORK=testnet

# Trusted mode default (true → verify proofs client-side).
NEXT_PUBLIC_TRUSTED_MODE=true

# Optional DAPI address overrides (comma-separated).
NEXT_PUBLIC_DAPI_ADDRESSES_TESTNET=
NEXT_PUBLIC_DAPI_ADDRESSES_MAINNET=

# Hide /broadcast + /wallet.
NEXT_PUBLIC_DISABLE_WRITE_MODE=false

# Rate provider: kucoin | coinbase | none.
NEXT_PUBLIC_RATE_PROVIDER=kucoin

# Optional URL to load an extended well-known registry (JSON).
NEXT_PUBLIC_WELL_KNOWN_URL=
